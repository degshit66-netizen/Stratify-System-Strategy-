{
  "name": "stratify-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.3.2",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.2",
    "date-fns": "^4.4.0",
    "dotenv": "^17.2.3",
    "esbuild": "^0.25.12",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "firebase": "^11.1.0",
    "framer-motion": "^12.42.2",
    "html2pdf.js": "^0.14.0",
    "idb-keyval": "^6.2.6",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.3",
    "pdf-lib": "^1.17.1",
    "puppeteer": "^25.3.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-barcode": "^1.6.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.1",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "~5.8.2",
    "vite": "^6.4.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "vite-plugin-pwa": "^1.3.0",
    "workbox-core": "^7.4.1",
    "workbox-precaching": "^7.4.1",
    "workbox-routing": "^7.4.1",
    "workbox-strategies": "^7.4.1",
    "workbox-window": "^7.4.1"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.stratify.app",
    "productName": "STRATIFY",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  }
}