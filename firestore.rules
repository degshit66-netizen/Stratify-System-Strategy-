rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    match /users/{userId} {
      allow read, write: if true;
    }
    
    match /tenants/{tenantId} {
      allow read, write: if true;
      
      match /ledger/{entryId} {
        allow read, write: if true;
      }
    }
  }
}
